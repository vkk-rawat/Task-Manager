# Required for Vercel Deployment

# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key

# Node Environment
NODE_ENV=production

# Optional (only if needed for development or custom setups)
# PORT=5000
# VITE_API_URL defaults to /api (handled by Vercel rewrites)
# CORS_ORIGIN not needed on Vercel (same-origin deployment)
