{
  "version": 2,
  "public": false,
  "buildCommand": "npm run build",
  "installCommand": "npm run install:all",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "functions": {
    "server/**/*.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "client/dist/index.html"
    }
  ]
}
